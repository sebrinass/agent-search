{
  "name": "agent-local-search",
  "version": "0.1.0",
  "description": "为 Agent 提供的本地联网搜索工具，支持 CLI 和 MCP 模式",
  "license": "MIT",
  "author": "sebrinass",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebrinass/agent-search.git"
  },
  "homepage": "https://github.com/sebrinass/agent-search#readme",
  "bugs": {
    "url": "https://github.com/sebrinass/agent-search/issues"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "model-context-protocol",
    "lobehub",
    "searxng",
    "search",
    "web-search",
    "claude",
    "ai",
    "hybrid-search"
  ],
  "type": "module",
  "bin": {
    "agent-search": "dist/cli/program.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js dist/**/*.js",
    "watch": "tsc --watch",
    "test": "cross-env SEARXNG_URL=https://test-searx.example.com tsx --no-cache __tests__/run-all.ts",
    "test:coverage": "cross-env SEARXNG_URL=https://test-searx.example.com tsx --no-cache __tests__/run-all.ts",
    "bootstrap": "npm install && npm run build",
    "inspector": "cross-env DANGEROUSLY_OMIT_AUTH=true npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mozilla/readability": "^0.6.0",
    "commander": "^14.0.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "happy-dom": "^20.8.3",
    "minisearch": "^7.2.0",
    "node-html-markdown": "^1.3.0",
    "quick-lru": "^7.3.0",
    "undici": "^6.20.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^22.17.2",
    "@types/supertest": "^6.0.3",
    "c8": "^10.1.3",
    "cross-env": "^10.1.0",
    "shx": "^0.4.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
