{
  "name": "augmented-search",
  "version": "1.1.0",
  "description": "增强型 MCP 搜索服务器，集成混合检索、代码文档搜索等功能",
  "license": "MIT",
  "author": "Based on mcp-searxng by Ihor Sokoliuk",
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "model-context-protocol",
    "lobehub",
    "searxng",
    "search",
    "web-search",
    "claude",
    "ai",
    "hybrid-search",
    "context7",
    "code-search"
  ],
  "type": "module",
  "bin": {
    "augmented-search": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "watch": "tsc --watch",
    "test": "cross-env SEARXNG_URL=https://test-searx.example.com tsx __tests__/run-all.ts",
    "test:coverage": "cross-env SEARXNG_URL=https://test-searx.example.com c8 --reporter=text tsx __tests__/run-all.ts",
    "bootstrap": "npm install && npm run build",
    "inspector": "cross-env DANGEROUSLY_OMIT_AUTH=true npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mozilla/readability": "^0.6.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "happy-dom": "^20.8.3",
    "jsdom": "^26.0.0",
    "minisearch": "^7.2.0",
    "node-html-markdown": "^1.3.0",
    "quick-lru": "^7.3.0",
    "undici": "^6.20.1"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@types/node": "^22.17.2",
    "@types/supertest": "^6.0.3",
    "c8": "^10.1.3",
    "cross-env": "^10.1.0",
    "shx": "^0.4.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
